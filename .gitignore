# --- environment / caches ---
.venv/
__pycache__/
*.pyc
*.egg-info/
.DS_Store
.pytest_cache/
# local Claude Code session state (plans, worktrees, agent logs)
.claude/

# --- secrets & raw data (never ship) ---
.secrets/
# third-party telemetry, some without a redistribution license
data/real/

# --- run outputs: ship ONLY the artifacts the paper cites; ignore all other run scratch ---
# Everything under outputs/ is ignored by default; the whitelist below re-includes exactly
# the logs + benchmarks referenced by the paper's reproducibility table (Table 10). This
# keeps intermediate ablation cells, *_run.log console dumps, *.salvage.jsonl, and scratch
# results out of the repo.
outputs/*
# benchmark result artifacts every paper number is read from
!outputs/agent_eval_results.json
!outputs/agent_eval_fewshot_n200_results.json
!outputs/head_to_head_stats.json
!outputs/technique_lift.json
!outputs/ablation_results.json
!outputs/baseline_zoo.json
!outputs/cost_model.json
!outputs/benchmark_results.json
!outputs/continuous_monitor.json
!outputs/monitor_gating.json
!outputs/monitor_sweep_gemini.json
!outputs/gemini_vs_claude.json
# per-turn agent logs (the audit trail stats.py recomputes CIs/McNemar from)
!outputs/agent_eval_turns.jsonl
!outputs/agent_eval_fewshot_turns.jsonl
!outputs/continuous_monitor_turns.jsonl
!outputs/gemini_zero_shot_turns.jsonl
!outputs/gemini_enhanced_turns.jsonl
# engineered-baseline head-to-head: provenance for the \ENG* macros in the paper
# (0.915 / 0.898 / 0.245 / 0.101 / 0.701), so a reviewer can verify those numbers
!outputs/engineered_baseline_h2h.json
# sim-to-real detector: real-hardware false-alarm rate (6.4%) + injected-fault recall (100%)
!outputs/real_detect.json

# --- internal notes not for publication ---
# draft partnership emails w/ third-party personal contacts
docs/OUTREACH.md
# internal self-critique / strategy — a reviewer roadmap of the paper's weak
# points in our own words; keep out of the public research repo
docs/PAPER_RECONCILIATION.md
docs/REAL_DATA_PIVOT.md

# --- paper build cruft (keep source .tex + figures + final pdf) ---
paper/page-*.png
paper/checkpage-*.png
# editor/backup + submission bundle + tectonic build tree (all regenerable)
paper/*.bak
paper/onnes_arxiv_submission.zip
paper/onnes_arxiv_build/
# stray scratch outputs written under scripts/
scripts/outputs/
# LaTeX build byproducts (regenerated by tectonic on every build)
paper/*.log
paper/*.aux
paper/*.out
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz

# paper kept out of this repo (lives elsewhere)
paper/
